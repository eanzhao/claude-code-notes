---
import "../styles/site.css";
import { withBasePath } from "../utils/withBasePath";

interface Props {
  title: string;
  description?: string;
}

const { title, description = "Claude Code 使用技巧与完整文档中文翻译" } = Astro.props;
const overviewUrl = withBasePath("docs/learning-roadmap");
---

<!doctype html>
<html lang="zh-CN">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <title>{title}</title>
  </head>
  <body>
    <div class="shell">
      <header class="site-header">
        <a class="brand" href={overviewUrl}>Claude Code 中文文档</a>
        <nav>
          <a href={overviewUrl}>学习路线</a>
          <a href="https://code.claude.com/docs/en/" target="_blank" rel="noopener noreferrer" class="github-link" aria-label="官方英文文档">
            <svg width="20" height="20" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.5">
              <path d="M11 3H17V9" stroke-linecap="round" stroke-linejoin="round"/>
              <path d="M17 3L9 11" stroke-linecap="round" stroke-linejoin="round"/>
              <path d="M15 11V16C15 16.5523 14.5523 17 14 17H4C3.44772 17 3 16.5523 3 16V6C3 5.44772 3.44772 5 4 5H9" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </a>
        </nav>
      </header>

      <main class="content">
        <slot />
      </main>
    </div>
  </body>
</html>

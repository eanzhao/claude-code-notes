---
import "../styles/site.css";
import { withBasePath } from "../utils/withBasePath";

interface Props {
  title: string;
  description?: string;
}

const { title, description = "Claude Code 使用技巧与完整文档中文翻译" } = Astro.props;
const overviewUrl = withBasePath("docs/learning-roadmap");
const officialDocsUrl = "https://code.claude.com/docs/en/";
const repositoryUrl = "https://github.com/eanzhao/claude-code-notes";
---

<!doctype html>
<html lang="zh-CN">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <title>{title}</title>
  </head>
  <body>
    <div class="shell">
      <header class="site-header">
        <a class="brand" href={overviewUrl}>Claude Code 中文文档</a>
        <nav class="site-nav">
          <a href={overviewUrl}>学习路线</a>
          <a href={officialDocsUrl} target="_blank" rel="noopener noreferrer" class="site-nav-link" aria-label="官方英文文档">
            官方英文
          </a>
          <a href={repositoryUrl} target="_blank" rel="noopener noreferrer" class="site-nav-link site-nav-link-repo" aria-label="GitHub 仓库">
            <svg class="site-nav-icon" viewBox="0 0 16 16" fill="currentColor" aria-hidden="true">
              <path d="M8 0C3.58 0 0 3.67 0 8.2C0 11.82 2.29 14.9 5.47 15.98C5.87 16.06 6.02 15.81 6.02 15.59C6.02 15.39 6.01 14.73 6.01 13.85C4 14.23 3.48 13.35 3.32 12.89C3.23 12.66 2.84 11.94 2.5 11.75C2.22 11.6 1.82 11.22 2.49 11.21C3.12 11.2 3.57 11.81 3.72 12.05C4.44 13.31 5.59 12.96 6.07 12.74C6.14 12.2 6.35 11.83 6.58 11.62C4.8 11.41 2.94 10.71 2.94 7.59C2.94 6.7 3.25 5.97 3.77 5.4C3.69 5.2 3.41 4.35 3.85 3.21C3.85 3.21 4.52 2.99 6.05 4.05C6.69 3.87 7.37 3.78 8.05 3.78C8.73 3.78 9.41 3.87 10.05 4.05C11.58 2.98 12.25 3.21 12.25 3.21C12.69 4.35 12.41 5.2 12.33 5.4C12.85 5.97 13.16 6.69 13.16 7.59C13.16 10.72 11.29 11.41 9.51 11.62C9.8 11.88 10.05 12.38 10.05 13.16C10.05 14.27 10.04 15.18 10.04 15.59C10.04 15.81 10.19 16.07 10.59 15.98C13.766 14.899 16 11.82 16 8.2C16 3.67 12.42 0 8 0Z"></path>
            </svg>
            <span class="visually-hidden">GitHub 仓库</span>
          </a>
        </nav>
      </header>

      <main class="content">
        <slot />
      </main>
    </div>
  </body>
</html>
